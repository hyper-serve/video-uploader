{
	"name": "@hyperserve/video-uploader-react",
	"version": "0.1.1",
	"author": "Ryan Trann",
	"description": "Composable React UI components for @hyperserve/video-uploader",
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"files": [
		"dist"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/hyper-serve/video-uploader.git",
		"directory": "packages/react"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": ["video", "upload", "react", "components", "ui"],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"build:watch": "tsc -p tsconfig.build.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "bun run build"
	},
	"peerDependencies": {
		"@hyperserve/video-uploader": "workspace:^",
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0"
	},
	"devDependencies": {
		"@hyperserve/video-uploader": "workspace:*",
		"@testing-library/react": "16.3.2",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"jsdom": "28.1.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"typescript": "5.9.3",
		"vitest": "4.0.18"
	}
}
