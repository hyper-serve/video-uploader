{
	"name": "@hyperserve/video-uploader-adapter-hyperserve",
	"version": "0.1.1",
	"author": "Ryan Trann",
	"description": "Hyperserve adapter for @hyperserve/video-uploader",
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"files": [
		"dist"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/hyper-serve/video-uploader.git",
		"directory": "packages/upload-adapter-hyperserve"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": ["video", "upload", "hyperserve", "adapter"],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"build:watch": "tsc -p tsconfig.build.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "bun run build"
	},
	"dependencies": {
		"@hyperserve/hyperserve-js": "^0.1.0"
	},
	"peerDependencies": {
		"@hyperserve/video-uploader": "workspace:^",
		"react-native-background-upload": ">=6.0.0"
	},
	"peerDependenciesMeta": {
		"react-native-background-upload": {
			"optional": true
		}
	},
	"devDependencies": {
		"@hyperserve/video-uploader": "workspace:*",
		"@types/node": "22.15.0",
		"typescript": "5.9.3",
		"vitest": "4.0.18"
	}
}
