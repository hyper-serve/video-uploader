---
import EditLink from "virtual:starlight/components/EditLink";
import LastUpdated from "virtual:starlight/components/LastUpdated";
import Pagination from "virtual:starlight/components/Pagination";
import wordmark from "../../../public/hyperserve-wordmark.svg?raw";

// Override of Starlight's Footer. Keeps the default edit-link / pagination meta,
// and replaces the "Built with Starlight" kudos with a "Built by Hyperserve"
// credit. The wordmark is inlined (not an <img>) so its currentColor fills
// inherit the link color and work in both light and dark themes.
---

<footer class="sl-flex">
	<div class="meta sl-flex">
		<EditLink />
		<LastUpdated />
	</div>
	<Pagination />

	<a class="built-by sl-flex" href="https://hyperserve.io" rel="me">
		<span>Built by</span>
		<span class="wordmark" set:html={wordmark} />
	</a>
</footer>

<style>
	@layer starlight.core {
		footer {
			flex-direction: column;
			gap: 1.5rem;
		}
		.meta {
			gap: 0.75rem 3rem;
			justify-content: space-between;
			flex-wrap: wrap;
			margin-top: 3rem;
			font-size: var(--sl-text-sm);
			color: var(--sl-color-gray-3);
		}
		.meta > :global(p:only-child) {
			margin-inline-start: auto;
		}

		.built-by {
			align-items: center;
			gap: 0.5em;
			margin: 1.5rem auto;
			font-size: var(--sl-text-xs);
			text-decoration: none;
			color: var(--sl-color-gray-3);
		}
		.built-by:hover {
			color: var(--sl-color-accent);
		}
		.wordmark :global(svg) {
			display: block;
			width: auto;
			height: 1.5rem;
		}
	}
</style>
