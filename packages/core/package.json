{
	"name": "@hyperserve/video-uploader",
	"version": "0.1.1",
	"author": "Ryan Trann",
	"description": "Headless cross-platform video upload component with pluggable adapters for third-party video backends.",
	"license": "MIT",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"files": [
		"dist"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/hyper-serve/video-uploader.git",
		"directory": "packages/core"
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": ["video", "upload", "react", "react-native", "headless", "cross-platform"],
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"build:watch": "tsc -p tsconfig.build.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "bun run build"
	},
	"peerDependencies": {
		"react": ">=18.0.0",
		"expo-video-metadata": ">=1.0.0",
		"expo-video-thumbnails": ">=8.0.0",
		"react-native-background-upload": ">=6.0.0"
	},
	"peerDependenciesMeta": {
		"expo-video-metadata": {
			"optional": true
		},
		"expo-video-thumbnails": {
			"optional": true
		},
		"react-native-background-upload": {
			"optional": true
		}
	},
	"devDependencies": {
		"@testing-library/react": "16.3.2",
		"@types/node": "22.15.0",
		"@types/react": "19.2.14",
		"jsdom": "28.1.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"typescript": "5.9.3",
		"vitest": "4.0.18"
	}
}
